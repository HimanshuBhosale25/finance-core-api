# App
APP_ENV=development
APP_DEBUG=True
APP_NAME="Finance Backend"

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=finance_db

# JWT
JWT_SECRET_KEY=super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis
REDIS_URL=redis://localhost:6379
REDIS_RATE_LIMIT_PER_MINUTE=60